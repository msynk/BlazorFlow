@page "/examples/basic"

<PageTitle>BlazorFlow - Basic Example</PageTitle>

<ExampleScaffold Title="Basic"
                 Summary="The minimal flow: a handful of nodes and edges with panning, zooming, selection and connecting.">
    <FlowCanvas Nodes="_nodes" Edges="_edges" FitViewOnInit="true">
        <Background Variant="BackgroundVariant.Dots" Gap="16" />
        <Controls />
        <MiniMap />
    </FlowCanvas>
</ExampleScaffold>

@code {
    private List<Node> _nodes = [];
    private List<Edge> _edges = [];

    protected override void OnInitialized()
    {
        _nodes =
        [
            new Node { Id = "1", Type = "input",  Label = "Node 1", Position = new(250, 5) },
            new Node { Id = "2",                  Label = "Node 2", Position = new(100, 100) },
            new Node { Id = "3",                  Label = "Node 3", Position = new(400, 100) },
            new Node { Id = "4", Type = "output", Label = "Node 4", Position = new(400, 200) },
        ];

        _edges =
        [
            new Edge { Id = "e1-2", Source = "1", Target = "2", Label = "this is an edge label" },
            new Edge { Id = "e1-3", Source = "1", Target = "3" },
            new Edge { Id = "e3-4", Source = "3", Target = "4", Animated = true, Label = "animated" },
        ];
    }
}
