@page "/examples/default-node-overwrite"

<PageTitle>BlazorFlow - Default Node Overwrite</PageTitle>

<ExampleScaffold Title="Default Node Overwrite"
                 Summary="Replace the built-in 'default' node renderer with your own. Here every default node becomes a rounded card with an accent bar, while input/output keep their built-in look.">
    <FlowCanvas Nodes="_nodes" Edges="_edges" FitViewOnInit="true">
        <NodeTemplate Context="node">
            @if (node.Type == "default")
            {
                <Handle Type="HandleType.Target" Position="Position.Top" />
                <div class="card-node">
                    <span class="card-node__bar"></span>
                    <span class="card-node__label">@node.Label</span>
                </div>
                <Handle Type="HandleType.Source" Position="Position.Bottom" />
            }
            else
            {
                <BlazorFlow.Internal.DefaultNode Node="node" />
            }
        </NodeTemplate>
        <ChildContent>
            <Background Variant="BackgroundVariant.Dots" Gap="16" />
            <Controls />
        </ChildContent>
    </FlowCanvas>
</ExampleScaffold>

<style>
    .card-node { display:flex; align-items:center; gap:8px; padding:2px 4px; }
    .card-node__bar { width:6px; height:24px; border-radius:3px; background:linear-gradient(#6366f1,#a855f7); }
    .card-node__label { font-weight:600; }
</style>

@code {
    private List<Node> _nodes = [];
    private List<Edge> _edges = [];

    protected override void OnInitialized()
    {
        _nodes =
        [
            new Node { Id = "1", Type = "input", Label = "Input", Position = new(250, 20) },
            new Node { Id = "2", Label = "Custom default A", Position = new(150, 130) },
            new Node { Id = "3", Label = "Custom default B", Position = new(380, 130) },
            new Node { Id = "4", Type = "output", Label = "Output", Position = new(280, 250) },
        ];
        _edges =
        [
            new Edge { Id = "e1-2", Source = "1", Target = "2" },
            new Edge { Id = "e1-3", Source = "1", Target = "3" },
            new Edge { Id = "e2-4", Source = "2", Target = "4" },
        ];
    }
}
