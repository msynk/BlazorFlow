@page "/examples/drag-n-drop"

<PageTitle>BlazorFlow - Drag and Drop</PageTitle>

<ExampleScaffold Title="Drag and Drop"
                 Summary="Drag a node type from the sidebar and drop it onto the canvas. The drop position is converted from screen to flow coordinates so the node lands under the cursor.">
    <div class="dnd">
        <aside class="dnd__sidebar">
            <p class="text-muted">Drag these onto the canvas →</p>
            <div class="dnd__item dnd__item--input" draggable="true" @ondragstart="@(() => _dragType = "input")">Input Node</div>
            <div class="dnd__item" draggable="true" @ondragstart="@(() => _dragType = "default")">Default Node</div>
            <div class="dnd__item dnd__item--output" draggable="true" @ondragstart="@(() => _dragType = "output")">Output Node</div>
        </aside>
        <div class="dnd__canvas" @ondragover:preventDefault="true" @ondrop="OnDrop">
            <FlowCanvas @ref="_flow" Nodes="_nodes" Edges="_edges" FitViewOnInit="true">
                <Background Variant="BackgroundVariant.Dots" Gap="16" />
                <Controls />
            </FlowCanvas>
        </div>
    </div>
</ExampleScaffold>

<style>
    .dnd { display:flex; height:100%; }
    .dnd__sidebar { width:180px; padding:12px; border-right:1px solid var(--bf-border); background:#fafafa; }
    .dnd__sidebar p { font-size:12px; margin:0 0 10px; }
    .dnd__canvas { flex:1; position:relative; }
    .dnd__item {
        padding:10px; margin-bottom:10px; border:1px solid #ccc; border-radius:8px;
        background:#fff; cursor:grab; text-align:center; font-size:13px; font-weight:600;
    }
    .dnd__item--input { border-color:#16a34a; }
    .dnd__item--output { border-color:#6366f1; }
</style>

@code {
    private FlowCanvas? _flow;
    private List<Node> _nodes = [];
    private List<Edge> _edges = [];
    private string _dragType = "default";
    private int _id;

    protected override void OnInitialized()
    {
        _nodes = [ new Node { Id = "start", Type = "input", Label = "Drop nodes anywhere", Position = new(120, 40), Width = 200 } ];
        _id = 0;
    }

    private void OnDrop(DragEventArgs e)
    {
        if (_flow is null) return;
        var pos = _flow.ScreenToFlowPosition(e.ClientX, e.ClientY);
        _id++;
        _nodes.Add(new Node
        {
            Id = $"dnd-{_id}",
            Type = _dragType,
            Label = $"{char.ToUpper(_dragType[0])}{_dragType[1..]} {_id}",
            Position = new(pos.X - 75, pos.Y - 20),
        });
        _flow.Refresh(remeasure: true);
    }
}
