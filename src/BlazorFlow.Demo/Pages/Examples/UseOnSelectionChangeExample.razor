@page "/examples/use-on-selection-change"

<PageTitle>BlazorFlow - Selection Change</PageTitle>

<ExampleScaffold Title="Selection Change"
                 Summary="OnSelectionChange fires whenever the selected nodes or edges change. Select elements (Shift-drag for a box) to see the current selection listed.">
    <FlowCanvas Nodes="_nodes" Edges="_edges" FitViewOnInit="true"
                SelectionOnDrag="true" OnSelectionChange="OnSelectionChange">
        <Background Variant="BackgroundVariant.Dots" Gap="16" />
        <Controls />
        <Panel Position="top-right">
            <div class="sel-panel">
                <div><strong>selected nodes:</strong> @(_nodeIds.Count == 0 ? "—" : string.Join(", ", _nodeIds))</div>
                <div><strong>selected edges:</strong> @(_edgeIds.Count == 0 ? "—" : string.Join(", ", _edgeIds))</div>
            </div>
        </Panel>
    </FlowCanvas>
</ExampleScaffold>

<style>
    .sel-panel { background:#fff; border:1px solid var(--bf-border); border-radius:8px; padding:8px 10px; font-size:12px; min-width:200px; box-shadow:var(--bf-shadow); }
</style>

@code {
    private List<Node> _nodes = [];
    private List<Edge> _edges = [];
    private List<string> _nodeIds = [];
    private List<string> _edgeIds = [];

    protected override void OnInitialized()
    {
        _nodes =
        [
            new Node { Id = "1", Type = "input", Label = "Node 1", Position = new(250, 20) },
            new Node { Id = "2", Label = "Node 2", Position = new(150, 140) },
            new Node { Id = "3", Label = "Node 3", Position = new(380, 140) },
            new Node { Id = "4", Type = "output", Label = "Node 4", Position = new(250, 260) },
        ];
        _edges =
        [
            new Edge { Id = "e1-2", Source = "1", Target = "2" },
            new Edge { Id = "e1-3", Source = "1", Target = "3" },
            new Edge { Id = "e2-4", Source = "2", Target = "4" },
        ];
    }

    private void OnSelectionChange(SelectionChange change)
    {
        _nodeIds = change.Nodes.Select(n => n.Id).ToList();
        _edgeIds = change.Edges.Select(e => e.Id).ToList();
    }
}
