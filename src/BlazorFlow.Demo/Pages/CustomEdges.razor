@page "/custom-edges"

<PageTitle>BlazorFlow - Custom Edges</PageTitle>

<div class="demo-header">
    <h3>Custom Edges, BaseEdge &amp; Edge Toolbar</h3>
    <p class="text-muted">
        Edges are drawn with a custom <strong>EdgeTemplate</strong> built on <strong>BaseEdge</strong> +
        <strong>EdgeText</strong> (colored by edge data). Selecting an edge reveals an
        <strong>EdgeToolbar</strong> (HTML overlay) to recolor or delete it. The connection line uses a
        smooth-step path.
    </p>
</div>

<DemoCode />

<div class="demo-canvas" style="height: calc(100vh - 240px);">
    <FlowCanvas Nodes="_nodes" Edges="_edges" FitViewOnInit="true"
                ConnectionLineType="EdgeType.SmoothStep"
                DefaultEdgeType="EdgeType.SmoothStep">
        <EdgeTemplate Context="ctx">
            <BaseEdge Path="@ctx.Geometry.Path"
                      Stroke="@((ctx.Edge.Data as string) ?? "var(--bf-edge-stroke)")"
                      StrokeWidth="@(ctx.Edge.Selected ? 3 : 2)"
                      Label="@ctx.Edge.Label"
                      LabelX="@ctx.Geometry.LabelX"
                      LabelY="@ctx.Geometry.LabelY" />
        </EdgeTemplate>

        <EdgeLabelTemplate Context="ctx">
            @if (ctx.Edge.Selected)
            {
                <EdgeToolbar>
                    <button class="btn-mini" @onclick="() => Recolor(ctx.Edge)">🎨</button>
                    <button class="btn-mini danger" @onclick="() => Remove(ctx.Edge)">×</button>
                </EdgeToolbar>
            }
        </EdgeLabelTemplate>

        <ChildContent>
            <Background Variant="BackgroundVariant.Dots" Gap="20" />
            <Controls />
            <MiniMap />
        </ChildContent>
    </FlowCanvas>
</div>

<style>
    .btn-mini { border:1px solid #ddd; background:#fff; border-radius:4px; cursor:pointer; padding:1px 6px; font-size:13px; }
    .btn-mini.danger { background:#fee2e2; color:#b91c1c; border-color:#fca5a5; }
    .btn-mini:hover { background:#f3f4f6; }
</style>

@code {
    private List<Node> _nodes = new();
    private List<Edge> _edges = new();

    protected override void OnInitialized()
    {
        _nodes =
        [
            new Node { Id = "1", Type = "input",  Label = "Start",  Position = new(240, 20) },
            new Node { Id = "2",                  Label = "Branch", Position = new(100, 160) },
            new Node { Id = "3",                  Label = "Branch", Position = new(400, 160) },
            new Node { Id = "4", Type = "output", Label = "End",    Position = new(250, 300) },
        ];

        _edges =
        [
            new Edge { Id = "e1-2", Source = "1", Target = "2", Label = "yes", Data = "#16a34a" },
            new Edge { Id = "e1-3", Source = "1", Target = "3", Label = "no",  Data = "#dc2626" },
            new Edge { Id = "e2-4", Source = "2", Target = "4", Label = "done", Data = "#2563eb" },
        ];
    }

    private void Recolor(Edge edge)
    {
        var colors = new[] { "#16a34a", "#dc2626", "#2563eb", "#9333ea", "#ea580c" };
        edge.Data = colors[Random.Shared.Next(colors.Length)];
    }

    private void Remove(Edge edge) => _edges.RemoveAll(e => e.Id == edge.Id);
}
