@page "/examples/custom-minimap-node"

<PageTitle>BlazorFlow - Custom MiniMap Node</PageTitle>

<ExampleScaffold Title="Custom MiniMap Node"
                 Summary="Color the minimap nodes by type and outline the selected node, using the MiniMap's NodeColorFunc and NodeStrokeColorFunc. Select a node to see its minimap outline.">
    <FlowCanvas Nodes="_nodes" Edges="_edges" FitViewOnInit="true">
        <Background Variant="BackgroundVariant.Dots" Gap="16" />
        <Controls />
        <MiniMap Width="240" Height="180"
                 NodeColorFunc="NodeColor"
                 NodeStrokeColorFunc="NodeStroke"
                 NodeStrokeWidth="3"
                 BorderRadius="6" />
    </FlowCanvas>
</ExampleScaffold>

@code {
    private List<Node> _nodes = [];
    private List<Edge> _edges = [];

    protected override void OnInitialized()
    {
        _nodes =
        [
            new Node { Id = "1", Type = "input", Label = "Input", Position = new(250, 20) },
            new Node { Id = "2", Label = "Default A", Position = new(120, 140) },
            new Node { Id = "3", Label = "Default B", Position = new(380, 140) },
            new Node { Id = "4", Type = "output", Label = "Output", Position = new(250, 260) },
        ];
        _edges =
        [
            new Edge { Id = "e1-2", Source = "1", Target = "2" },
            new Edge { Id = "e1-3", Source = "1", Target = "3" },
            new Edge { Id = "e2-4", Source = "2", Target = "4" },
            new Edge { Id = "e3-4", Source = "3", Target = "4" },
        ];
    }

    private string NodeColor(Node n) => n.Type switch
    {
        "input" => "#16a34a",
        "output" => "#6366f1",
        _ => "#fbbf24",
    };

    private string NodeStroke(Node n) => n.Selected ? "#111827" : "transparent";
}
