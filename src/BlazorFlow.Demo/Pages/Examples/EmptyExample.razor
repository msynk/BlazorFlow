@page "/examples/empty"

<PageTitle>BlazorFlow - Empty</PageTitle>

<ExampleScaffold Title="Empty"
                 Summary="An empty canvas. Use the buttons to add nodes at runtime, then connect them.">
    <Toolbar>
        <button class="btn btn-sm btn-primary" @onclick="AddNode">Add node</button>
        <button class="btn btn-sm" @onclick="Reset">Clear</button>
        <span class="text-muted">@_nodes.Count node(s)</span>
    </Toolbar>
    <ChildContent>
        <FlowCanvas @ref="_flow" Nodes="_nodes" Edges="_edges">
            <Background Variant="BackgroundVariant.Dots" Gap="16" />
            <Controls />
        </FlowCanvas>
    </ChildContent>
</ExampleScaffold>

@code {
    private FlowCanvas? _flow;
    private List<Node> _nodes = [];
    private List<Edge> _edges = [];
    private int _id;

    private void AddNode()
    {
        _id++;
        _nodes.Add(new Node
        {
            Id = _id.ToString(),
            Label = $"Node {_id}",
            Position = new(Random.Shared.Next(0, 400), Random.Shared.Next(0, 300)),
        });
        _flow?.Refresh(remeasure: true);
    }

    private void Reset()
    {
        _nodes.Clear();
        _edges.Clear();
        _id = 0;
    }
}
