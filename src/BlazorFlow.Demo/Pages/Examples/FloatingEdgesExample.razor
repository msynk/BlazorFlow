@page "/examples/floating-edges"

<PageTitle>BlazorFlow - Floating Edges</PageTitle>

<ExampleScaffold Title="Floating Edges"
                 Summary="Edges attach to the point on each node's border that faces the other node, recomputed live as you drag. The custom EdgeTemplate uses GraphUtils.GetFloatingEdgeParams.">
    <FlowCanvas Nodes="_nodes" Edges="_edges" FitViewOnInit="true" ConnectionMode="ConnectionMode.Loose">
        <NodeTemplate Context="node">
            <Handle Type="HandleType.Source" Position="Position.Top" Class="floating-handle" />
            <Handle Type="HandleType.Target" Position="Position.Bottom" Class="floating-handle" />
            <div class="floating-node">@node.Label</div>
        </NodeTemplate>
        <EdgeTemplate Context="ctx">
            @{
                var path = FloatingPath(ctx.Edge);
            }
            <BaseEdge Path="@path" StrokeWidth="2" />
        </EdgeTemplate>
        <ChildContent>
            <Background Variant="BackgroundVariant.Dots" Gap="16" />
            <Controls />
        </ChildContent>
    </FlowCanvas>
</ExampleScaffold>

<style>
    .floating-node {
        display:flex; align-items:center; justify-content:center;
        width:60px; height:60px; border-radius:50%;
        background:#fff; border:2px solid #6366f1; font-weight:600; font-size:12px;
    }
    .floating-handle { opacity:0; }
</style>

@code {
    private List<Node> _nodes = [];
    private List<Edge> _edges = [];

    protected override void OnInitialized()
    {
        var positions = new (double x, double y)[]
        {
            (0, 0), (250, -120), (250, 120), (500, 0), (250, 0),
        };
        _nodes = positions.Select((p, i) => new Node
        {
            Id = (i + 1).ToString(),
            Label = $"N{i + 1}",
            Position = new(p.x, p.y),
            Width = 60,
            Height = 60,
        }).ToList();

        _edges =
        [
            new Edge { Id = "e5-1", Source = "5", Target = "1" },
            new Edge { Id = "e5-2", Source = "5", Target = "2" },
            new Edge { Id = "e5-3", Source = "5", Target = "3" },
            new Edge { Id = "e5-4", Source = "5", Target = "4" },
        ];
    }

    private string FloatingPath(Edge edge)
    {
        var s = _nodes.FirstOrDefault(n => n.Id == edge.Source);
        var t = _nodes.FirstOrDefault(n => n.Id == edge.Target);
        if (s is null || t is null) return string.Empty;

        var (src, srcPos, tgt, tgtPos) = GraphUtils.GetFloatingEdgeParams(s, t);
        return EdgePath.Compute(EdgeType.Bezier, src.X, src.Y, srcPos, tgt.X, tgt.Y, tgtPos).Path;
    }
}
