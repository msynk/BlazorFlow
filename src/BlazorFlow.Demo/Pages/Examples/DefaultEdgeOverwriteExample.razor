@page "/examples/default-edge-overwrite"

<PageTitle>BlazorFlow - Default Edge Overwrite</PageTitle>

<ExampleScaffold Title="Default Edge Overwrite"
                 Summary="DefaultEdgeOptions apply to every newly created edge. Here new connections are animated smooth-step edges with a closed arrow and a thicker indigo stroke.">
    <FlowCanvas Nodes="_nodes" Edges="_edges" FitViewOnInit="true" DefaultEdgeOptions="_options">
        <Background Variant="BackgroundVariant.Dots" Gap="16" />
        <Controls />
    </FlowCanvas>
</ExampleScaffold>

@code {
    private List<Node> _nodes = [];
    private List<Edge> _edges = [];

    private readonly DefaultEdgeOptions _options = new()
    {
        Type = EdgeType.SmoothStep,
        Animated = true,
        MarkerEnd = true,
        MarkerType = MarkerType.ArrowClosed,
        StrokeWidth = 2.5,
        Stroke = "#6366f1",
    };

    protected override void OnInitialized()
    {
        _nodes =
        [
            new Node { Id = "1", Type = "input", Label = "Drag from my handle", Position = new(250, 20), Width = 200 },
            new Node { Id = "2", Label = "to here", Position = new(120, 170) },
            new Node { Id = "3", Label = "or here", Position = new(420, 170) },
        ];
        _edges = [ new Edge { Id = "e1-2", Source = "1", Target = "2" } ];
    }
}
