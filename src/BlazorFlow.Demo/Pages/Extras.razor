@page "/extras"

<PageTitle>BlazorFlow - Theming &amp; Extras</PageTitle>

<div class="demo-header">
    <h3>Theming, Viewport Portal, Single Resize &amp; Graph Utils</h3>
    <p class="text-muted">
        Switch the <strong>color mode</strong>, toggle <strong>loose connections</strong> (connect any handle
        to any handle) and <strong>node origin</strong> (center vs top-left). The teal box is a
        <strong>ViewportPortal</strong> annotation (pans/zooms with the graph). The green node uses a single
        <strong>NodeResizeControl</strong>. Select a node and click <em>Neighbors</em> to use <strong>GraphUtils</strong>.
    </p>
</div>

<DemoCode />

<div class="demo-canvas" style="height: calc(100vh - 240px);">
    <FlowCanvas @ref="_flow"
                Nodes="_nodes"
                Edges="_edges"
                FitViewOnInit="true"
                ColorMode="_colorMode"
                ConnectionMode="_loose ? ConnectionMode.Loose : ConnectionMode.Strict"
                NodeOrigin="_centerOrigin ? new XYPosition(0.5, 0.5) : new XYPosition(0, 0)"
                HideAttribution="_hideAttribution"
                OnNodeClick="n => _selected = n">
        <NodeTemplate Context="node">
            @if (node.Type == "sized")
            {
                <NodeResizeControl Position="ResizeDirection.BottomRight" MinWidth="120" MinHeight="60" />
                <Handle Type="HandleType.Target" Position="Position.Top" />
                <div style="display:flex;align-items:center;justify-content:center;height:100%;font-weight:600;">@node.Label</div>
                <Handle Type="HandleType.Source" Position="Position.Bottom" />
            }
            else
            {
                <BlazorFlow.Internal.DefaultNode Node="node" />
            }
        </NodeTemplate>

        <ChildContent>
            <Background Variant="BackgroundVariant.Dots" Gap="20" />
            <Controls />
            <MiniMap />

            <ViewportPortal>
                <div class="portal-annotation">Region A &middot; flow-space annotation</div>
            </ViewportPortal>

            <Panel Position="top-left">
                <div class="toolbar">
                    <label><input type="checkbox" @bind="_dark" @bind:after="ApplyTheme" /> Dark mode</label>
                    <label><input type="checkbox" @bind="_loose" /> Loose connections</label>
                    <label><input type="checkbox" @bind="_centerOrigin" /> Center node origin</label>
                    <label><input type="checkbox" @bind="_hideAttribution" /> Hide attribution</label>
                    <button class="btn btn-sm btn-primary" @onclick="ShowNeighbors">Neighbors of selected</button>
                    <div class="hint">@_info</div>
                </div>
            </Panel>
        </ChildContent>
    </FlowCanvas>
</div>

<style>
    .portal-annotation {
        position:absolute; transform:translate(440px, 40px);
        background:rgba(13,148,136,0.12); border:1px dashed #0d9488; color:#0f766e;
        padding:6px 10px; border-radius:6px; font-size:12px; white-space:nowrap; pointer-events:none;
    }
    .toolbar { display:flex; flex-direction:column; gap:5px; font-size:13px; }
    .toolbar label { display:flex; align-items:center; gap:6px; white-space:nowrap; }
    .toolbar .hint { font-size:12px; color:#666; max-width:220px; }
</style>

@code {
    private FlowCanvas? _flow;
    private List<Node> _nodes = new();
    private List<Edge> _edges = new();

    private bool _dark;
    private bool _loose;
    private bool _centerOrigin;
    private bool _hideAttribution;
    private ColorMode _colorMode = ColorMode.Light;
    private Node? _selected;
    private string _info = "No node selected.";

    protected override void OnInitialized()
    {
        _nodes =
        [
            new Node { Id = "1", Type = "input",  Label = "Source", Position = new(240, 30) },
            new Node { Id = "2", Type = "sized",  Label = "Resize ↘", Position = new(120, 170), Width = 150, Height = 70,
                       Style = "background:#dcfce7;border-color:#16a34a;" },
            new Node { Id = "3",                  Label = "Node C", Position = new(400, 180) },
            new Node { Id = "4", Type = "output", Label = "Sink",   Position = new(260, 320) },
        ];

        _edges =
        [
            new Edge { Id = "e1-2", Source = "1", Target = "2" },
            new Edge { Id = "e1-3", Source = "1", Target = "3" },
            new Edge { Id = "e2-4", Source = "2", Target = "4" },
            new Edge { Id = "e3-4", Source = "3", Target = "4" },
        ];
    }

    private void ApplyTheme() => _colorMode = _dark ? ColorMode.Dark : ColorMode.Light;

    private void ShowNeighbors()
    {
        if (_selected is null) { _info = "Select a node first."; return; }
        var incomers = GraphUtils.GetIncomers(_selected, _nodes, _edges).Select(n => n.Label ?? n.Id);
        var outgoers = GraphUtils.GetOutgoers(_selected, _nodes, _edges).Select(n => n.Label ?? n.Id);
        var connected = GraphUtils.GetConnectedEdges([_selected], _edges).Count;
        _info = $"{_selected.Label}: in [{string.Join(", ", incomers)}], out [{string.Join(", ", outgoers)}], {connected} edge(s).";
    }
}
