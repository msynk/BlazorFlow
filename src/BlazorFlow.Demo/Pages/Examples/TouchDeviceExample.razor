@page "/examples/touch-device"

<PageTitle>BlazorFlow - Touch Device</PageTitle>

<ExampleScaffold Title="Touch Device"
                 Summary="All interactions are built on pointer events, so dragging nodes, panning, connecting handles and box-selection work with touch as well as mouse. Try it on a touchscreen or with device emulation.">
    <FlowCanvas Nodes="_nodes" Edges="_edges" FitViewOnInit="true" SelectionOnDrag="false">
        <Background Variant="BackgroundVariant.Dots" Gap="16" />
        <Controls />
        <MiniMap />
    </FlowCanvas>
</ExampleScaffold>

@code {
    private List<Node> _nodes = [];
    private List<Edge> _edges = [];

    protected override void OnInitialized()
    {
        _nodes =
        [
            new Node { Id = "1", Type = "input", Label = "Tap & drag me", Position = new(220, 30), Width = 160 },
            new Node { Id = "2", Label = "Node 2", Position = new(120, 170) },
            new Node { Id = "3", Label = "Node 3", Position = new(360, 170) },
            new Node { Id = "4", Type = "output", Label = "Node 4", Position = new(240, 300) },
        ];
        _edges =
        [
            new Edge { Id = "e1-2", Source = "1", Target = "2" },
            new Edge { Id = "e1-3", Source = "1", Target = "3" },
            new Edge { Id = "e2-4", Source = "2", Target = "4" },
        ];
    }
}
