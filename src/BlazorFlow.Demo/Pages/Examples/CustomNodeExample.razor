@page "/examples/custom-node"

<PageTitle>BlazorFlow - Custom Node</PageTitle>

<ExampleScaffold Title="Custom Node"
                 Summary="A custom 'text updater' node with its own markup, an input bound to node data, and explicitly placed handles. Edits flow through to a connected output.">
    <FlowCanvas Nodes="_nodes" Edges="_edges" FitViewOnInit="true">
        <NodeTemplate Context="node">
            @if (node.Type == "textUpdater" && node.Data is TextData data)
            {
                <Handle Type="HandleType.Target" Position="Position.Top" />
                <div class="text-updater">
                    <label>Text:</label>
                    <input class="nodrag" value="@data.Text"
                           @oninput="e => OnText(node, e.Value?.ToString())"
                           @onpointerdown:stopPropagation="true" />
                </div>
                <Handle Type="HandleType.Source" Position="Position.Bottom" Id="a" />
            }
            else
            {
                <BlazorFlow.Internal.DefaultNode Node="node" />
            }
        </NodeTemplate>
        <ChildContent>
            <Background Variant="BackgroundVariant.Dots" Gap="16" />
            <Controls />
        </ChildContent>
    </FlowCanvas>
</ExampleScaffold>

<style>
    .text-updater { padding: 4px 2px; font-size: 12px; text-align: left; }
    .text-updater label { display:block; color:#555; margin-bottom:3px; }
    .text-updater input { width: 130px; padding: 3px 6px; border:1px solid #ddd; border-radius:5px; }
</style>

@code {
    public sealed class TextData { public string Text { get; set; } = ""; }

    private List<Node> _nodes = [];
    private List<Edge> _edges = [];

    protected override void OnInitialized()
    {
        _nodes =
        [
            new Node { Id = "node-1", Type = "textUpdater", Position = new(0, 0), Data = new TextData { Text = "hello" }, Width = 170 },
            new Node { Id = "node-2", Type = "output", Label = "(empty)", Position = new(0, 160) },
        ];
        _edges =
        [
            new Edge { Id = "e1-2", Source = "node-1", Target = "node-2", SourceHandle = "a", Animated = true },
        ];
        Sync();
    }

    private void OnText(Node node, string? value)
    {
        if (node.Data is TextData d) d.Text = value ?? "";
        Sync();
    }

    private void Sync()
    {
        var src = _nodes.First(n => n.Id == "node-1").Data as TextData;
        var output = _nodes.First(n => n.Id == "node-2");
        output.Label = string.IsNullOrEmpty(src?.Text) ? "(empty)" : src!.Text;
    }
}
