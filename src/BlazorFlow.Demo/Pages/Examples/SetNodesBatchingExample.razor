@page "/examples/set-nodes-batching"

<PageTitle>BlazorFlow - setNodes Batching</PageTitle>

<ExampleScaffold Title="setNodes Batching"
                 Summary="Add many nodes in a single batched update. AddNodes appends them all and triggers one measure pass instead of one per node.">
    <Toolbar>
        <button class="btn btn-sm btn-primary" @onclick="@(() => AddBatch(25))">Add 25</button>
        <button class="btn btn-sm btn-primary" @onclick="@(() => AddBatch(100))">Add 100</button>
        <button class="btn btn-sm" @onclick="Clear">Clear</button>
        <span class="text-muted">@_nodes.Count nodes</span>
    </Toolbar>
    <ChildContent>
        <FlowCanvas @ref="_flow" Nodes="_nodes" Edges="_edges" OnlyRenderVisibleElements="true">
            <Background Variant="BackgroundVariant.Dots" Gap="16" />
            <Controls />
            <MiniMap />
        </FlowCanvas>
    </ChildContent>
</ExampleScaffold>

@code {
    private FlowCanvas? _flow;
    private List<Node> _nodes = [];
    private List<Edge> _edges = [];
    private int _id;

    private void AddBatch(int count)
    {
        var batch = new Node[count];
        for (var i = 0; i < count; i++)
        {
            _id++;
            batch[i] = new Node
            {
                Id = _id.ToString(),
                Label = _id.ToString(),
                Position = new(Random.Shared.Next(0, 900), Random.Shared.Next(0, 600)),
                Width = 50, Height = 32,
            };
        }
        _flow?.AddNodes(batch); // single batched update
    }

    private void Clear()
    {
        _nodes.Clear();
        _edges.Clear();
        _id = 0;
        _flow?.Refresh(remeasure: true);
    }
}
