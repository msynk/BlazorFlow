@page "/examples/interactive-minimap"

<PageTitle>BlazorFlow - Interactive MiniMap</PageTitle>

<ExampleScaffold Title="Interactive MiniMap"
                 Summary="The minimap is both pannable and zoomable: drag inside it to move the viewport, and scroll over it to zoom the main flow.">
    <FlowCanvas Nodes="_nodes" Edges="_edges" FitViewOnInit="true">
        <Background Variant="BackgroundVariant.Dots" Gap="16" />
        <Controls />
        <MiniMap Pannable="true" Zoomable="true" Width="240" Height="180" />
    </FlowCanvas>
</ExampleScaffold>

@code {
    private List<Node> _nodes = [];
    private List<Edge> _edges = [];

    protected override void OnInitialized()
    {
        for (var i = 0; i < 12; i++)
        {
            _nodes.Add(new Node
            {
                Id = i.ToString(),
                Label = $"Node {i}",
                Position = new((i % 4) * 200, (i / 4) * 160),
            });
            if (i > 0)
                _edges.Add(new Edge { Id = $"e{i}", Source = (i - 1).ToString(), Target = i.ToString() });
        }
    }
}
