@namespace BlazorFlow

<div class="blazorflow__controls @(Orientation == ControlsOrientation.Horizontal ? "horizontal" : null)">
    <button type="button" class="blazorflow__controls-button" title="Zoom in" @onclick="() => Flow.ZoomIn()">
        <svg viewBox="0 0 24 24" width="14" height="14"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
    </button>
    <button type="button" class="blazorflow__controls-button" title="Zoom out" @onclick="() => Flow.ZoomOut()">
        <svg viewBox="0 0 24 24" width="14" height="14"><path d="M5 12h14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
    </button>
    <button type="button" class="blazorflow__controls-button" title="Fit view" @onclick="() => Flow.FitView()">
        <svg viewBox="0 0 24 24" width="14" height="14"><path d="M4 9V5a1 1 0 0 1 1-1h4M15 4h4a1 1 0 0 1 1 1v4M20 15v4a1 1 0 0 1-1 1h-4M9 20H5a1 1 0 0 1-1-1v-4" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
    </button>
    @ChildContent
</div>

@code {
    [CascadingParameter] private IFlowContext Flow { get; set; } = default!;

    [Parameter] public ControlsOrientation Orientation { get; set; } = ControlsOrientation.Vertical;

    /// <summary>Extra control buttons appended after the built-ins.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
