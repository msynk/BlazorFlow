@page "/examples/cancel-connection"

<PageTitle>BlazorFlow - Cancel Connection</PageTitle>

<ExampleScaffold Title="Cancel Connection"
                 Summary="Start dragging a connection from a handle, then press Escape to cancel it before releasing. The status line tracks the connection lifecycle.">
    <Toolbar>
        <span class="text-muted">status: <strong>@_status</strong></span>
    </Toolbar>
    <ChildContent>
        <FlowCanvas Nodes="_nodes" Edges="_edges" FitViewOnInit="true"
                    OnConnectStart="OnStart" OnConnectEnd="OnEnd">
            <Background Variant="BackgroundVariant.Dots" Gap="16" />
            <Controls />
        </FlowCanvas>
    </ChildContent>
</ExampleScaffold>

@code {
    private List<Node> _nodes = [];
    private List<Edge> _edges = [];
    private string _status = "idle";

    protected override void OnInitialized()
    {
        _nodes =
        [
            new Node { Id = "1", Type = "input", Label = "Start dragging, then press Esc", Position = new(140, 40), Width = 240 },
            new Node { Id = "2", Label = "Target", Position = new(220, 220) },
        ];
        _edges = [];
    }

    private void OnStart(ConnectionStartInfo info) => _status = $"connecting from node {info.NodeId}…";

    private void OnEnd(ConnectEndInfo info) =>
        _status = info.IsValid ? "connected" : "cancelled (no connection made)";
}
