@namespace BlazorFlow

<svg class="blazorflow__minimap @(Pannable ? "pannable" : null)"
     width="@Width" height="@Height" viewBox="@ViewBox"
     @onpointerdown="OnPointerDown"
     @onpointermove="OnPointerMove"
     @onpointerup="OnPointerUp"
     @onpointerleave="OnPointerUp"
     @onwheel="OnWheel"
     @onwheel:preventDefault="Zoomable">
    @foreach (var node in Flow.CurrentNodes)
    {
        if (node.Hidden) continue;
        var r = node.GetRect();
        @if (NodeTemplate is not null)
        {
            <g transform="@($"translate({Inv(r.X)},{Inv(r.Y)})")">
                @NodeTemplate(node)
            </g>
        }
        else
        {
            <rect class="blazorflow__minimap-node @(node.Selected ? "selected" : null) @NodeClassFunc?.Invoke(node)"
                  x="@Inv(r.X)" y="@Inv(r.Y)"
                  width="@Inv(r.Width)" height="@Inv(r.Height)"
                  rx="@Inv(BorderRadius)"
                  fill="@(NodeColorFunc?.Invoke(node) ?? NodeColor)"
                  stroke="@(NodeStrokeColorFunc?.Invoke(node) ?? NodeStrokeColor)"
                  stroke-width="@Inv(NodeStrokeWidth)" />
        }
    }
    <path class="blazorflow__minimap-mask"
          d="@MaskPath"
          fill="@MaskColor"
          fill-rule="evenodd" />
</svg>

@code {
    [CascadingParameter] private IFlowContext Flow { get; set; } = default!;

    [Parameter] public int Width { get; set; } = 200;
    [Parameter] public int Height { get; set; } = 150;
    [Parameter] public string NodeColor { get; set; } = "#e2e2e2";
    [Parameter] public string MaskColor { get; set; } = "rgba(120,120,120,0.25)";

    /// <summary>Default node outline color.</summary>
    [Parameter] public string NodeStrokeColor { get; set; } = "transparent";

    /// <summary>Default node outline width (in flow units).</summary>
    [Parameter] public double NodeStrokeWidth { get; set; } = 2;

    /// <summary>Corner radius of the default node rectangles.</summary>
    [Parameter] public double BorderRadius { get; set; } = 2;

    /// <summary>Per-node fill color. Overrides <see cref="NodeColor"/> when provided.</summary>
    [Parameter] public Func<Node, string>? NodeColorFunc { get; set; }

    /// <summary>Per-node outline color. Overrides <see cref="NodeStrokeColor"/> when provided.</summary>
    [Parameter] public Func<Node, string>? NodeStrokeColorFunc { get; set; }

    /// <summary>Per-node extra CSS class for the minimap rectangle.</summary>
    [Parameter] public Func<Node, string?>? NodeClassFunc { get; set; }

    /// <summary>Optional SVG template for each minimap node, rendered translated to the node origin.</summary>
    [Parameter] public RenderFragment<Node>? NodeTemplate { get; set; }

    /// <summary>When true, clicking or dragging on the minimap pans the main viewport.</summary>
    [Parameter] public bool Pannable { get; set; } = true;

    /// <summary>When true, scrolling over the minimap zooms the main viewport.</summary>
    [Parameter] public bool Zoomable { get; set; }

    private Rect _bounds;
    private bool _panning;

    private string ViewBox => string.Create(CultureInfo.InvariantCulture,
        $"{_bounds.X} {_bounds.Y} {_bounds.Width} {_bounds.Height}");

    protected override void OnParametersSet() => _bounds = ComputeBounds();

    private Rect ComputeBounds()
    {
        // Union of all node rects, padded; falls back to the visible viewport area.
        double minX = double.MaxValue, minY = double.MaxValue, maxX = double.MinValue, maxY = double.MinValue;
        bool any = false;
        foreach (var n in Flow.CurrentNodes)
        {
            if (n.Hidden) continue;
            any = true;
            var r = n.GetRect();
            minX = Math.Min(minX, r.X);
            minY = Math.Min(minY, r.Y);
            maxX = Math.Max(maxX, r.Right);
            maxY = Math.Max(maxY, r.Bottom);
        }

        if (!any)
            return new Rect(0, 0, Width, Height);

        // Include the current viewport rectangle so the mask is always visible.
        var vp = VisibleRect();
        minX = Math.Min(minX, vp.X);
        minY = Math.Min(minY, vp.Y);
        maxX = Math.Max(maxX, vp.Right);
        maxY = Math.Max(maxY, vp.Bottom);

        var w = maxX - minX;
        var h = maxY - minY;
        var pad = Math.Max(w, h) * 0.1 + 10;
        return new Rect(minX - pad, minY - pad, w + pad * 2, h + pad * 2);
    }

    private Rect VisibleRect()
    {
        var vp = Flow.Viewport;
        var pane = Flow.PaneSize;
        var topLeft = vp.ScreenToFlow(0, 0);
        return new Rect(topLeft.X, topLeft.Y, pane.Width / vp.Zoom, pane.Height / vp.Zoom);
    }

    private string MaskPath
    {
        get
        {
            var b = _bounds;
            var v = VisibleRect();
            // Outer rect (clockwise) + inner viewport rect (counter-clockwise) => mask everything except viewport.
            return string.Create(CultureInfo.InvariantCulture,
                $"M{b.X},{b.Y}h{b.Width}v{b.Height}h{-b.Width}z " +
                $"M{v.X},{v.Y}v{v.Height}h{v.Width}v{-v.Height}z");
        }
    }

    private static string Inv(double v) => v.ToString(CultureInfo.InvariantCulture);

    private void OnPointerDown(PointerEventArgs e)
    {
        if (!Pannable || e.Button != 0) return;
        _panning = true;
        PanTo(e.OffsetX, e.OffsetY);
    }

    private void OnPointerMove(PointerEventArgs e)
    {
        if (_panning) PanTo(e.OffsetX, e.OffsetY);
    }

    private void OnPointerUp(PointerEventArgs e) => _panning = false;

    private void OnWheel(WheelEventArgs e)
    {
        if (!Zoomable) return;
        var vp = Flow.Viewport;
        var factor = e.DeltaY < 0 ? 1.15 : 1 / 1.15;
        Flow.SetViewport(vp with { Zoom = vp.Zoom * factor });
    }

    /// <summary>Centers the main viewport on the flow point under the given minimap-local pixel.</summary>
    private void PanTo(double offsetX, double offsetY)
    {
        if (Width <= 0 || Height <= 0) return;
        var fx = _bounds.X + offsetX * (_bounds.Width / Width);
        var fy = _bounds.Y + offsetY * (_bounds.Height / Height);

        var vp = Flow.Viewport;
        var pane = Flow.PaneSize;
        var x = pane.Width / 2 - fx * vp.Zoom;
        var y = pane.Height / 2 - fy * vp.Zoom;
        Flow.SetViewport(new Viewport(x, y, vp.Zoom));
    }
}
