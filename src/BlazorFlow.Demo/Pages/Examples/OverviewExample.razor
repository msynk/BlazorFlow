@page "/examples/overview"

<PageTitle>BlazorFlow - Overview</PageTitle>

<ExampleScaffold Title="Overview"
                 Summary="A larger graph combining node types, several edge types (animated, labelled, smooth-step), a background, controls and a minimap."
                 Height="calc(100vh - 230px)">
    <FlowCanvas Nodes="_nodes" Edges="_edges" FitViewOnInit="true" MinZoom="0.2" MaxZoom="4">
        <Background Variant="BackgroundVariant.Dots" Gap="16" />
        <Controls />
        <MiniMap NodeColorFunc="NodeColor" />
        <Panel Position="top-left">
            <strong>BlazorFlow Overview</strong>
        </Panel>
    </FlowCanvas>
</ExampleScaffold>

@code {
    private List<Node> _nodes = [];
    private List<Edge> _edges = [];

    protected override void OnInitialized()
    {
        _nodes =
        [
            new Node { Id = "1", Type = "input", Label = "Input", Position = new(0, 0) },
            new Node { Id = "2", Label = "Default", Position = new(-120, 120) },
            new Node { Id = "3", Label = "Default", Position = new(120, 120) },
            new Node { Id = "4", Label = "Process", Position = new(0, 240), Style = "background:#dbeafe;border-color:#60a5fa;" },
            new Node { Id = "5", Label = "Decision", Position = new(-180, 360) },
            new Node { Id = "6", Label = "Step", Position = new(180, 360) },
            new Node { Id = "7", Type = "output", Label = "Output A", Position = new(-180, 480) },
            new Node { Id = "8", Type = "output", Label = "Output B", Position = new(180, 480) },
        ];

        _edges =
        [
            new Edge { Id = "e1-2", Source = "1", Target = "2", Animated = true },
            new Edge { Id = "e1-3", Source = "1", Target = "3", Animated = true },
            new Edge { Id = "e2-4", Source = "2", Target = "4", Type = EdgeType.SmoothStep },
            new Edge { Id = "e3-4", Source = "3", Target = "4", Type = EdgeType.SmoothStep },
            new Edge { Id = "e4-5", Source = "4", Target = "5", Label = "yes", Type = EdgeType.Step },
            new Edge { Id = "e4-6", Source = "4", Target = "6", Label = "no", Type = EdgeType.Step },
            new Edge { Id = "e5-7", Source = "5", Target = "7" },
            new Edge { Id = "e6-8", Source = "6", Target = "8", Type = EdgeType.Straight },
        ];
    }

    private string NodeColor(Node n) => n.Type switch
    {
        "input" => "#6ede87",
        "output" => "#6865f0",
        _ => "#ddd",
    };
}
