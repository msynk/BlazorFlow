@page "/examples/controlled-viewport"

<PageTitle>BlazorFlow - Controlled Viewport</PageTitle>

<ExampleScaffold Title="Controlled Viewport"
                 Summary="Drive the viewport from your own state. The pan/zoom values update as you interact, and the buttons set the viewport imperatively.">
    <Toolbar>
        <span class="text-muted">x: @_vp.X.ToString("0") · y: @_vp.Y.ToString("0") · zoom: @_vp.Zoom.ToString("0.00")</span>
        <button class="btn btn-sm" @onclick="@(() => _flow?.SetViewport(new Viewport(0, 0, 1)))">Reset</button>
        <button class="btn btn-sm" @onclick="@(() => _flow?.SetCenter(0, 0, 1.5))">Center origin</button>
        <button class="btn btn-sm" @onclick="@(() => _flow?.FitView())">Fit</button>
    </Toolbar>
    <ChildContent>
        <FlowCanvas @ref="_flow" Nodes="_nodes" Edges="_edges" FitViewOnInit="true"
                    OnViewportChanged="v => { _vp = v; StateHasChanged(); }">
            <Background Variant="BackgroundVariant.Dots" Gap="16" />
            <Controls />
            <MiniMap />
        </FlowCanvas>
    </ChildContent>
</ExampleScaffold>

@code {
    private FlowCanvas? _flow;
    private List<Node> _nodes = [];
    private List<Edge> _edges = [];
    private Viewport _vp = Viewport.Identity;

    protected override void OnInitialized()
    {
        _nodes =
        [
            new Node { Id = "1", Type = "input", Label = "Node 1", Position = new(0, 0) },
            new Node { Id = "2", Label = "Node 2", Position = new(150, 120) },
            new Node { Id = "3", Type = "output", Label = "Node 3", Position = new(-50, 220) },
        ];
        _edges =
        [
            new Edge { Id = "e1-2", Source = "1", Target = "2" },
            new Edge { Id = "e2-3", Source = "2", Target = "3" },
        ];
    }
}
