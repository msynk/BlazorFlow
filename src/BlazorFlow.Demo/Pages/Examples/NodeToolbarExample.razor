@page "/examples/node-toolbar"

<PageTitle>BlazorFlow - Node Toolbar</PageTitle>

<ExampleScaffold Title="Node Toolbar"
                 Summary="A NodeToolbar anchored to the selected node stays a constant screen size while zooming. Select a node to recolor or delete it; change the toolbar position.">
    <Toolbar>
        <label>position:
            <select @onchange="e => _position = Enum.Parse<Position>(e.Value!.ToString()!)">
                <option value="Top">Top</option>
                <option value="Bottom">Bottom</option>
                <option value="Left">Left</option>
                <option value="Right">Right</option>
            </select>
        </label>
    </Toolbar>
    <ChildContent>
        <FlowCanvas Nodes="_nodes" Edges="_edges" FitViewOnInit="true">
            <NodeTemplate Context="node">
                <NodeToolbar Position="_position">
                    <button class="btn btn-sm" @onclick="() => Recolor(node)">🎨</button>
                    <button class="btn btn-sm" @onclick="() => Remove(node)">🗑</button>
                </NodeToolbar>
                <Handle Type="HandleType.Target" Position="Position.Top" />
                <div class="tb-node">@node.Label</div>
                <Handle Type="HandleType.Source" Position="Position.Bottom" />
            </NodeTemplate>
            <ChildContent>
                <Background Variant="BackgroundVariant.Dots" Gap="16" />
                <Controls />
            </ChildContent>
        </FlowCanvas>
    </ChildContent>
</ExampleScaffold>

<style>
    .tb-node { padding:10px 16px; font-weight:600; }
</style>

@code {
    private List<Node> _nodes = [];
    private List<Edge> _edges = [];
    private Position _position = Position.Top;

    protected override void OnInitialized()
    {
        _nodes =
        [
            new Node { Id = "1", Label = "Select me", Position = new(160, 60), Style = "background:#fef9c3;" },
            new Node { Id = "2", Label = "Or me", Position = new(220, 200), Style = "background:#dbeafe;" },
        ];
        _edges = [ new Edge { Id = "e1-2", Source = "1", Target = "2" } ];
    }

    private void Recolor(Node node)
    {
        var colors = new[] { "#dbeafe", "#dcfce7", "#fee2e2", "#fef9c3", "#f3e8ff" };
        node.Style = $"background:{colors[Random.Shared.Next(colors.Length)]};";
    }

    private void Remove(Node node)
    {
        _nodes.Remove(node);
        _edges.RemoveAll(e => e.Source == node.Id || e.Target == node.Id);
    }
}
